APP_ENV=production
DATABASE_URL="postgresql://username:password@127.0.0.1:5432/rungoal"
JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_REFRESH_SECRET="replace-with-a-different-32-character-secret"
ADMIN_JWT_SECRET="replace-with-another-32-character-secret"
CORS_ORIGINS="https://run.example.com"
# Only keep these for the first boot when the Admin table is empty.
ADMIN_SEED_USERNAME="admin"
ADMIN_SEED_PASSWORD="replace-with-a-strong-initial-password"
PORT=3000
