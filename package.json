{
  "name": "sport-app",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @sport-app/web dev",
    "dev:admin": "pnpm --filter @sport-app/admin dev",
    "dev:server": "cargo run --manifest-path apps/server/Cargo.toml",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check:server": "cargo check --manifest-path apps/server/Cargo.toml"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20"
  }
}
